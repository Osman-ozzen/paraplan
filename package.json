{
  "name": "paraplan",
  "version": "2.0.0",
  "description": "ParaPlan - Akıllı bütçe, hedef ve finans yönetimi",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron .",
    "veri-aktar": "node scripts/veri-aktar.js",
    "deploy": "echo '⚠️  Otomatik deploy kaldırıldı. CI/CD kullanın veya manuel push yapın.'",
    "lint": "eslint src/ server/ --ext .js,.jsx --max-warnings=50 || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:ios": "npm run build && npx cap sync && npx cap open ios",
    "mobile:android": "npm run build && npx cap sync && npx cap open android",
    "mobile:dev": "npx cap serve"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "vite-plugin-pwa": "^1.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "vite": "^5.3.4",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  },
  "author": "ParaPlan",
  "build": {
    "appId": "com.paraplan.app",
    "productName": "ParaPlan",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.icns",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.icns",
      "category": "Finance"
    }
  },
  "allowScripts": {
    "electron@42.4.0": true
  }
}
