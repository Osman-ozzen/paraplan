{
  "name": "butce-takip",
  "version": "1.0.0",
  "description": "Bütçe Takip Uygulaması - Gelir, gider, kar/zarar takibi ve grafiksel raporlama",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && node server/index.js",
    "server": "node server/index.js",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron .",
    "veri-aktar": "node scripts/veri-aktar.js",
    "deploy": "npm run build && git add . && git commit -m 'deploy' && git push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.butce-takip.app",
    "productName": "Bütçe Takip",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "allowScripts": {
    "electron@42.4.0": true
  }
}
